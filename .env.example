# =============================================================================
# mphinance environment configuration
# =============================================================================
# Copy to .env for local dev (auto-loaded via python-dotenv), OR set these as
# environment secrets in Google Jules / CI / Cloud Run.
#
# Secrets are read env-first by gcp/secrets.py:get_secret(). The Firebase
# "VaultGuard" backend is only consulted on Michael's local box (when a
# service_account.json is present) — on Jules/CI these env vars ARE the source.
# =============================================================================

# ---- Required to run the dossier pipeline -----------------------------------
# Gemini powers the AI narrative stage (and the architect/Substack loops).
GEMINI_API_KEY=your-gemini-api-key

# ---- TickerTrace (institutional flows) --------------------------------------
# Defaults to https://api.tickertrace.pro; pipeline degrades gracefully if down.
TICKERTRACE_API_BASE=https://api.tickertrace.pro

# ---- Tradier (options / gamma-pin screener) — optional ----------------------
TRADIER_API_KEY=your-tradier-api-key
TRADIER_ACCESS_TOKEN=your-tradier-access-token
TRADIER_ACCOUNT_ID=your-tradier-account-id

# ---- Discord notifications — optional ---------------------------------------
# WEBHOOK_SAM_MPH: daily dossier summary post.
WEBHOOK_SAM_MPH=https://discord.com/api/webhooks/your-id/your-token
# DISCORD_BOT_TOKEN: used by scripts/sam_discord_monitor.py for channel digests.
DISCORD_BOT_TOKEN=your-discord-bot-token
# Additional webhooks for the NiceGUI screener (WEBHOOK_<NAME> -> UI label).
WEBHOOK_TRADING=https://discord.com/api/webhooks/your-id/your-token
WEBHOOK_RESEARCH=https://discord.com/api/webhooks/your-id/your-token

# ---- Substack publishing — optional -----------------------------------------
SUBSTACK_SID=your-substack-session-cookie
SUBSTACK_PUB_URL=https://yourpublication.substack.com

# ---- Stripe (revenue stats) — optional --------------------------------------
STRIPE_SECRET_KEY=sk_live_or_test_key

# ---- Google integrations — optional -----------------------------------------
# Deploy wheel_scanner/google_sheets_script.js and paste the Web App URL.
GOOGLE_SHEETS_WEBHOOK=https://script.google.com/macros/s/your-script-id/exec
GOOGLE_API_KEY=your-google-api-key

# ---- TastyTrade transaction sync — optional ---------------------------------
TASTYTRADE_CLIENT_SECRET=your-tastytrade-client-secret
TASTYTRADE_REFRESH_TOKEN=your-tastytrade-refresh-token

# ---- VaultGuard REST server auth — optional (local only) --------------------
VAULTGUARD_API_KEY=your-vaultguard-api-key

# ---- Path overrides — optional (sensible repo-relative defaults) ------------
# VOPR_PATH=/path/to/VoPR        # optional sibling repo for IV smoothing
# FIREBASE_CREDENTIALS=/path/to/service_account.json  # local VaultGuard only
